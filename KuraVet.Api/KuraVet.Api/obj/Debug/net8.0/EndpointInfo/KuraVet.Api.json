        ],
        "summary": "Lista todos os tutores",
        "description": "Retorna todos os tutores cadastrados no sistema KuraVet.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Tutor"
        ],
        "summary": "Adicionar novo tutor",
        "description": "Cadastra um novo tutor no banco de dados.",
        "requestBody": {
