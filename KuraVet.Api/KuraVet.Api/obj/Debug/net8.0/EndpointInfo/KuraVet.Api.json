  },
  "components": {
    "schemas": {
      "CheckinHistorico": {
        "required": [
          "corMucosa",
          "dataCheckin",
          "frequenciaRespiratoria",
          "nivelHidratacao",
          "petId",
          "tempoPreenchimentoCapilar"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "dataCheckin": {
            "type": "string",
            "format": "date-time"
          },
          "frequenciaRespiratoria": {
            "type": "integer",
            "format": "int32"
          },
          "tempoPreenchimentoCapilar": {
            "type": "integer",
            "format": "int32"
          },
          "corMucosa": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "nivelHidratacao": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "nivelRiscoIA": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          },
          "petId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "EventoConsulta": {
        "required": [
          "dataEvento",
          "petId",
          "tipoEvento",
          "veterinarioResponsavel"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "tipoEvento": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "dataEvento": {
            "type": "string",
            "format": "date-time"
          },
          "descricao": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "veterinarioResponsavel": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "petId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Pet": {
        "required": [
          "nome",
          "tutorId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nome": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "tutorId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "Tutor": {
        "required": [
          "nome"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nome": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}