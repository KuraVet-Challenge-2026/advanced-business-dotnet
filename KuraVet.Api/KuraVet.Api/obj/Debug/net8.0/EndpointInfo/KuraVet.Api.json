            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "EventoConsulta"
        ],
        "summary": "Editar evento existente",
        "description": "Atualiza as informações de um evento clínico já registrado.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventoConsulta"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EventoConsulta"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EventoConsulta"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "EventoConsulta"
        ],
        "summary": "Deletar um evento",
        "description": "Remove permanentemente um evento clínico do sistema.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/EventoConsulta/pet/{petId}": {
      "get": {
        "tags": [
          "EventoConsulta"
        ],
        "summary": "Obter linha do tempo clínica do Pet",
        "description": "Busca todos os eventos clínicos atrelados a um Pet, ordenados por data.",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
