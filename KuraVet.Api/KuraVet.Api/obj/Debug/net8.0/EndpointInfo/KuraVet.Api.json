{
  "openapi": "3.0.1",
  "info": {
    "title": "KuraVet API",
    "description": "API RESTful para o ecossistema de saúde veterinária contínua KuraVet.",
    "version": "v1"
  },
  "paths": {
    "/api/Checkin": {
      "post": {
        "tags": [
          "Checkin"
        ],
        "summary": "Registra um novo Check-in de saúde física para um Pet.",
        "description": "Exemplo de requisição:\r\n            \r\n    POST /api/Checkin\r\n    {\r\n       \"frequenciaRespiratoria\": 25,\r\n       \"tempoPreenchimentoCapilar\": 1,\r\n       \"corMucosa\": \"Rosada\",\r\n       \"nivelHidratacao\": \"Normal\",\r\n       \"petId\": 1\r\n    }",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinHistorico"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinHistorico"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinHistorico"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Check-in registrado com sucesso."
          },
          "400": {
            "description": "Se os dados enviados forem inválidos ou incompletos.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Checkin/{id}": {
      "get": {
        "tags": [
          "Checkin"
        ],
        "summary": "Busca um Check-in específico pelo seu ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "O ID do Check-in no banco de dados.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna os dados do Check-in solicitado."
          },
          "404": {
            "description": "Se o Check-in não for encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Checkin"
        ],
        "summary": "Atualiza os dados de um Check-in existente.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do Check-in a ser atualizado.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "O JSON contendo os novos dados do check-in.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinHistorico"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinHistorico"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CheckinHistorico"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Check-in atualizado com sucesso."
          },
          "400": {
            "description": "Se o ID da URL for diferente do ID no corpo da requisição.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Se o Check-in não existir.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Checkin"
        ],
        "summary": "Deleta permanentemente um Check-in do histórico do Pet.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do Check-in a ser deletado.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Remoção concluída com sucesso."
          },
          "404": {
            "description": "Se o Check-in não for encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Checkin/pet/{petId}": {
      "get": {
        "tags": [
          "Checkin"
        ],
        "summary": "Lista o histórico completo de Check-ins de um Pet específico.",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "description": "O ID do Pet (ex: 1).",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna a lista de check-ins ordenados por data."
          },
          "404": {
            "description": "Se o Pet não possuir nenhum histórico.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/Checkin/risco/{nivelRisco}": {
      "get": {
        "tags": [
          "Checkin"
        ],
        "summary": "Filtra os Check-ins baseados no nível de Risco definido pela IA.",
        "parameters": [
          {
            "name": "nivelRisco",
            "in": "path",
            "description": "O nível de risco (ex: Baixo, Moderado, Grave).",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna os alertas correspondentes ao nível de risco."
          }
        }
      }
    },
    "/api/EventoConsulta": {
      "get": {
        "tags": [
          "EventoConsulta"
        ],
